{
  "name": "@git-switchboard/docs-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:demo-frame": "bun run ../packages/git-switchboard/scripts/generate-demo-frame.tsx > generated/terminal-frame.json",
    "generate:cli-docs": "cd ../packages/git-switchboard && bunx --bun cli-forge generate-documentation ./src/cli.ts --format json --output /tmp/cli-docs-raw && bun run scripts/generate-cli-docs.ts /tmp/cli-docs-raw/git-switchboard.json ../../docs-site/generated/cli-docs.json",
    "generate": "mkdir -p generated && pnpm generate:demo-frame && pnpm generate:cli-docs",
    "dev": "vike dev",
    "build": "pnpm generate && vike build && pnpm exec pagefind --site dist/client",
    "preview": "pnpm generate && vike build && pnpm exec pagefind --site dist/client && vike preview"
  },
  "dependencies": {
    "@shikijs/rehype": "^3.21.0",
    "gray-matter": "^4.0.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rehype-github-alerts": "^4.2.0",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-directive": "^3.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "shiki": "^3.21.0",
    "unified": "^11.0.5",
    "vike": "^0.4.256",
    "vike-react": "^0.6.21"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "pagefind": "^1.4.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.2",
    "vite": "^7.3.1"
  },
  "nx": {
    "name": "docs-site",
    "targets": {
      "build": {
        "outputs": ["{projectRoot}/dist"]
      },
      "deploy": {
        "dependsOn": ["build"],
        "executor": "nx-github-pages:deploy",
        "options": {
          "remote": "https://github.com/git-switchboard/git-switchboard.git",
          "directory": "{projectRoot}/dist/client"
        }
      }
    }
  }
}
