{
  "name": "git-switchboard",
  "targets": {
    "run": {
      "command": "bun run packages/git-switchboard/src/cli.ts"
    },
    "build": {
      "outputs": ["{projectRoot}/dist"]
    },
    "build:native": {
      "command": "bun {projectRoot}/scripts/build-native.js",
      "outputs": ["{projectRoot}/native-builds"],
      "dependsOn": ["^build:native"]
    }
  }
}
