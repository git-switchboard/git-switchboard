{
  "name": "git-switchboard",
  "targets": {
    "validate-readme": {
      "command": "node scripts/validate-readme.mjs {projectRoot}",
      "cache": false
    },
    "run": {
      "command": "bun run packages/git-switchboard/src/cli.ts"
    },
    "build": {
      "outputs": ["{projectRoot}/dist"]
    },
    "build:native": {
      "command": "bun scripts/build-native.js",
      "options": {
        "cwd": {"projectRoot"}
      },
      "outputs": ["{projectRoot}/native-builds"],
      "dependsOn": ["^build:native"]
    }
  }
}
