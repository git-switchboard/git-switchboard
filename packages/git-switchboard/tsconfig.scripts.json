{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist-scripts",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "tsBuildInfoFile": "../../dist/tsc/git-switchboard.lib.tsbuildinfo",
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/react",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "lib": ["ESNext"],
    "strict": true
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/*.spec.ts", "**/*.test.ts"],
  "references": []
}
